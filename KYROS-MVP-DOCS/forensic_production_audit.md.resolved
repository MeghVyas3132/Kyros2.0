## 11. 📦 CODE-LEVEL IMPROVEMENTS

### Refactor 1: Split `engine.py:generate()` Into Orchestrator

```python
# Pseudocode for refactored engine
class AllocationEngine:
    async def generate(self, grn_id, brand_id, db) -> AllocationSession:
        context = await self._build_context(grn_id, brand_id, db)     # Load all data
        session = await self._init_session(context, db)                # Create/reset session
        
        for grn_line in context.grn_lines:
            result = await self._allocate_sku(grn_line, context, db)   # Per-SKU logic
            if result:
                self._batch.extend(result.lines)
                self._flush_if_needed(db)                              # flush, NOT commit
        
        await self._finalize(session, db)                              # Single commit
        return session
    
    async def _allocate_sku(self, grn_line, ctx, db) -> SkuAllocationResult:
        available = self._compute_available(grn_line, ctx)
        eligible = self._filter_eligible(ctx.stores, grn_line.sku, ctx)
        scores = self._score_stores(eligible, grn_line.sku, ctx)
        demands = self._compute_demands(eligible, grn_line.sku, ctx)
        distribution = self._distribute(scores, demands, available, grn_line.sku, ctx)
        final = self._apply_constraints(distribution, available, grn_line.sku, ctx)
        return self._build_lines(final, demands, scores, grn_line.sku, ctx)
```

### Refactor 2: Normalize Scoring

```python
def score_stores(self, sku, stores, ...) -> dict[UUID, ScoreData]:
    # Compute raw values
    raw_ros = {s.id: ros_by_attribute.get((s.id, key), {}).get("ros", 0) for s in stores}
    raw_grades = {s.id: GRADE_SCORES.get(grade, 2) for s in stores}
    raw_cover_inv = {s.id: 1/max(self._attribute_cover(s.id, inventory), 0.1) for s in stores}
    
    # Normalize to [0, 1] using min-max scaling
    def normalize(values: dict) -> dict:
        vals = list(values.values())
        lo, hi = min(vals), max(vals)
        if hi == lo: return {k: 0.5 for k in values}
        return {k: (v - lo) / (hi - lo) for k, v in values.items()}
    
    norm_ros = normalize(raw_ros)
    norm_grade = normalize(raw_grades)
    norm_cover = normalize(raw_cover_inv)
    
    return {
        s.id: ScoreData(
            score=ROS_WEIGHT * norm_ros[s.id] + GRADE_WEIGHT * norm_grade[s.id] + COVER_WEIGHT * norm_cover[s.id],
            ...
        ) for s in stores
    }
```

### Refactor 3: Cache Size Ratios

```python
# In AllocationEngine.__init__
self._size_ratio_cache: dict[tuple[str, str], dict[str, float]] = {}

# In generate(), before main loop:
await self._preload_size_ratios(brand_id, previous_season_id, db)

async def _preload_size_ratios(self, brand_id, season_id, db):
    """Pre-compute size ratios at brand level (shared across stores)."""
    categories = set(sku.category for sku in sku_map.values())
    for category in categories:
        ratios = await load_historical_size_ratios(
            brand_id=brand_id,
            product_category=category,
            store_id=None,  # brand-level
            db=db,
            historical_season_id=season_id,
        )
        self._size_ratio_cache[category] = ratios
```

### Refactor 4: Non-Linear Cannibalization

```python
def _apply_story_cannibalization(self, sku, allocations, existing_line_map, sku_map):
    # ... existing competing_count logic ...
    
    # Non-linear decay instead of fixed 0.65
    if competing_count > 0:
        factor = 1.0 / (1.0 + 0.15 * competing_count)  
        # 1 competitor: 0.87, 2: 0.77, 5: 0.57, 10: 0.40
    else:
        factor = 1.0
```
